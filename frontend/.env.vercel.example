# Copy these values into Vercel Project Settings -> Environment Variables.
# Vercel proxies these relative paths through frontend/vercel.json.
VITE_API_BASE_URL=/api
VITE_AI_BASE_URL=/ai

# Proxy destinations configured in frontend/vercel.json:
# /api -> https://eastern-dare-repeated-reach.trycloudflare.com/api
# /ai  -> https://eastern-dare-repeated-reach.trycloudflare.com/ai

# If you bypass Vercel rewrites and call services directly, use these values:
# VITE_API_BASE_URL=https://eastern-dare-repeated-reach.trycloudflare.com/api
# VITE_AI_BASE_URL=https://eastern-dare-repeated-reach.trycloudflare.com/ai
