# AI Camera Platform local MVP environment

APP_ENV=local
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://ai_camera:ai_camera@postgres:5432/ai_camera
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
JWT_SECRET=change-me
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AI_SERVICE_TOKEN=change-me-internal-token
RETENTION_DAYS=30

# AI service
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8010
CAMERA_ID=local-camera
CAMERA_SOURCE_TYPE=webcam
CAMERA_SOURCE_URI=0
PROCESSING_FPS=5
RECONNECT_BACKOFF_SECONDS=1
MAX_RECONNECT_BACKOFF_SECONDS=30
CAMERA_OPEN_TIMEOUT_MS=5000
CAMERA_READ_TIMEOUT_MS=5000
PERSON_CONFIDENCE_THRESHOLD=0.5
FACE_RECOGNITION_THRESHOLD=0.65
FACE_RECOGNITION_RUNTIME=simple
FACE_EMBEDDING_DIM=32
FACE_EMBEDDING_MODEL_NAME=simple-hash-face-embedding
EMBEDDING_STORE_RUNTIME=qdrant
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=3
CAMERA_OFFLINE_TIMEOUT_SECONDS=30
EVENT_COOLDOWN_SECONDS=60
KNOWN_PERSON_EVENT_COOLDOWN_SECONDS=120
UNKNOWN_PERSON_EVENT_COOLDOWN_SECONDS=120
RESTRICTED_ZONE_EVENT_COOLDOWN_SECONDS=300
CAMERA_OFFLINE_EVENT_COOLDOWN_SECONDS=300
PEOPLE_COUNT_INTERVAL_SECONDS=10
DETECTOR_RUNTIME=yolo
MODEL_PATH=/app/models/yolo-person.pt
TRACKER_RUNTIME=bytetrack
TRACKER_MATCH_THRESHOLD=0.3
TRACK_TTL_FRAMES=30
TRACKER_NEW_TRACK_THRESHOLD=0.5
SNAPSHOT_STORAGE_PATH=/data/snapshots

# Frontend
FRONTEND_API_BASE_URL=/api

# PostgreSQL
POSTGRES_DB=ai_camera
POSTGRES_USER=ai_camera
POSTGRES_PASSWORD=ai_camera

# Qdrant
QDRANT_COLLECTION_PERSON_FACE_EMBEDDINGS=person_face_embeddings
